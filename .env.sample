# --- LLM provider (OpenAI-compatible) ---
# This pilot defaults to a local LM Studio server. Point OPENAI_BASE_URL at
# any OpenAI-compatible endpoint (LM Studio, OpenAI, Azure OpenAI gateway,
# vLLM, etc.) and set OPENAI_MODEL to whatever model is registered there.
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL=google/gemma-4-e4b

# --- aegra backend (docker/aegra) ---
POSTGRES_USER=remotegraph
POSTGRES_PASSWORD=remotegraph_secret
POSTGRES_DB=remotegraph
AUTH_TYPE=noop

# --- open-langgraph-platform backend (docker/open-langgraph) ---
# DATABASE_URL=postgresql+asyncpg://remotegraph:remotegraph_secret@postgres:5432/remotegraph
